# =============================================================================
# MXroute Manager — environment configuration
# =============================================================================
# Copy to .env and edit:  cp .env.example .env
#
# Full reference: docs/configuration.md
#
# Minimum to run locally:
#   MX_SERVER, MX_USER, MX_API_KEY, ADMIN_PASSWORD, SECRET_KEY
# =============================================================================


# -----------------------------------------------------------------------------
# MXroute API (required)
# -----------------------------------------------------------------------------
MX_SERVER=yourmxserver.mxrouting.net
MX_USER=your_mxroute_username
MX_API_KEY=your_mxroute_api_key


# -----------------------------------------------------------------------------
# Core security
# -----------------------------------------------------------------------------
# Flask session signing — generate a long random string before production
SECRET_KEY=generate_a_long_random_string_for_session_encryption

# Set true when the app is served over HTTPS (recommended behind a reverse proxy)
FORCE_HTTPS=false

# Number of trusted reverse proxies in front of the app. Controls how many
# X-Forwarded-* hops are honored for the real client IP (used by rate limiting).
# Set to the number of proxies you run (e.g. 1 for a single NPM/nginx); 0 disables.
TRUSTED_PROXY_COUNT=1


# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Set true to require OIDC/SSO sign-in (configure the variables below)
OIDC_ENABLED=false

OIDC_CLIENT_ID=your_oidc_client_id
OIDC_CLIENT_SECRET=your_oidc_client_secret
OIDC_DISCOVERY_URL=https://auth.example.com/.well-known/openid-configuration
OIDC_REDIRECT_URI=https://your-domain.com/oidc/callback
OIDC_SCOPES=openid email profile groups
OIDC_ADMIN_USERS=admin1@example.com,admin2@example.com
OIDC_ADMIN_GROUP=administrators

# Local admin fallback (also sole login when OIDC_ENABLED=false)
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_to_a_secure_password
# One-shot recovery: set true and restart to re-hash ADMIN_PASSWORD from .env when the DB
# already has a hash (e.g. password changed in .env after first startup). Remove afterward.
# ADMIN_PASSWORD_FORCE_SYNC=false


# -----------------------------------------------------------------------------
# Cloudflare (optional — DNS wizard, one-click fixes, reset portal CNAMEs)
# -----------------------------------------------------------------------------
CF_API_TOKEN=your_cloudflare_api_token
CF_ACCOUNT_ID=your_cloudflare_account_id

# Optional Origin CA key; default path uses NPM Let's Encrypt + CF_API_TOKEN instead
# CF_ORIGIN_CA_KEY=your_origin_ca_key


# -----------------------------------------------------------------------------
# DNS defaults
# -----------------------------------------------------------------------------
# DMARC TXT value for Cloudflare auto-setup and DNS health checks
DMARC_RECORD=v=DMARC1; p=none; sp=none; adkim=r; aspf=r;


# -----------------------------------------------------------------------------
# Mailbox password reset (optional)
# -----------------------------------------------------------------------------
# MAILBOX_RESET_ENABLED=false
# RESET_SMTP_HOST=smtp.example.com
# RESET_SMTP_PORT=587
# RESET_SMTP_USER=notifications@example.com
# RESET_SMTP_PASSWORD=your_smtp_password
# RESET_SMTP_FROM=MXroute Manager <noreply@example.com>
# RESET_SMTP_USE_TLS=true


# -----------------------------------------------------------------------------
# Branded reset portals (optional — requires Cloudflare + Nginx Proxy Manager)
# See docs/reverse-proxy.md
# -----------------------------------------------------------------------------
# Public hostname users CNAME to (no scheme/path), e.g. mxtools.example.com
# RESET_PORTAL_CNAME_TARGET=manager.example.com

# NPM_API_URL=https://npm.example.com
# NPM_IDENTITY=admin@example.com
# NPM_SECRET=your_npm_password
# NPM_FORWARD_HOST=192.168.1.10
# NPM_FORWARD_PORT=5000
# NPM_TLS_VERIFY=true
# NPM_LETSENCRYPT_EMAIL=admin@example.com


# -----------------------------------------------------------------------------
# Storage and logging
# -----------------------------------------------------------------------------
# Defaults to mxroute-manager.db in the app directory; use /data/mxroute-manager.db in Docker
# DATABASE_FILE=./mxroute-manager.db
LOG_DIR=./logs


# -----------------------------------------------------------------------------
# Development only
# -----------------------------------------------------------------------------
# PORT=5000
