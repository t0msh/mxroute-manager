# --- MXroute API ---
MX_SERVER=blizzard.mxrouting.net
MX_USER=your_mxroute_username
MX_API_KEY=your_mxroute_api_key

# --- Cloudflare (optional — for automatic DNS record setup) ---
CF_API_TOKEN=your_cloudflare_api_token
CF_ACCOUNT_ID=your_cloudflare_account_id

# --- Authentication ---
# Set to false for local username/password login only
OIDC_ENABLED=true
OIDC_CLIENT_ID=your_oidc_client_id
OIDC_CLIENT_SECRET=your_oidc_client_secret
OIDC_DISCOVERY_URL=https://auth.example.com/.well-known/openid-configuration
OIDC_REDIRECT_URI=https://your-domain.com/oidc/callback
OIDC_SCOPES=openid email profile groups
OIDC_ADMIN_USERS=admin1@example.com,admin2@example.com
OIDC_ADMIN_GROUP=administrators

# Flask session signing key — generate a long random string before production
SECRET_KEY=generate_a_long_random_string_for_session_encryption

# Set to true when serving over HTTPS (required for local-auth deployments behind TLS)
FORCE_HTTPS=false

# --- Local admin fallback (used when OIDC is enabled, or as sole login when OIDC is disabled) ---
ADMIN_USER=admin
ADMIN_PASSWORD=change_this_to_a_secure_password

# --- DNS ---
# DMARC TXT value used for Cloudflare auto-setup and DNS health checks
DMARC_RECORD=v=DMARC1; p=none; sp=none; adkim=r; aspf=r;

# --- Storage & logging ---
# Defaults to mxroute-manager.db in the app directory; use /data/mxroute-manager.db in Docker
# DATABASE_FILE=./mxroute-manager.db
LOG_DIR=./logs

# --- Server (optional) ---
# PORT=5000
